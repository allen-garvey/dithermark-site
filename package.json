{
  "name": "dithermark-site",
  "version": "1.0.0",
  "description": "Support and marketing website for Dithermark app",
  "main": "public_html/index.html",
  "scripts": {
    "start": "php -S localhost:3000 -t public_html",
    "build": "sass --no-source-map sass/style.scss public_html/assets/style.css",
    "deploy": "sass --no-source-map sass/style.scss public_html/assets/style.css --style=compressed",
    "watch": "sass --no-source-map --watch sass/style.scss public_html/assets/style.css"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/allen-garvey/dithermark-site.git"
  },
  "author": "Allen Garvey",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/allen-garvey/dithermark-site/issues"
  },
  "homepage": "https://github.com/allen-garvey/dithermark-site#readme",
  "dependencies": {},
  "devDependencies": {
    "sass": "1.99.0"
  }
}